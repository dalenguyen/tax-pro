{
  "name": "tax-mcp-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/tax-mcp/src",
  "projectType": "library",
  "tags": ["scope:libs", "type:mcp"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/libs/tax-mcp/dist"],
      "options": {
        "command": "pnpm esbuild libs/tax-mcp/src/main.ts --bundle --platform=node --target=node22 --format=cjs --outfile=libs/tax-mcp/dist/main.js"
      }
    },
    "pack": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npx @anthropic-ai/mcpb pack",
        "cwd": "libs/tax-mcp"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsx libs/tax-mcp/src/main.ts"
      }
    }
  }
}
