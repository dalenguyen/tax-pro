rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User profile ────────────────────────────────────────────────────────
    // Each user owns exactly one doc keyed on their Firebase uid.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ─── Tax years ─────────────────────────────────────────────────────────
      match /taxYears/{taxYearId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // ─── Income entries ──────────────────────────────────────────────────
        match /incomeEntries/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // ─── Expense entries ─────────────────────────────────────────────────
        match /expenseEntries/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // ─── Investments ─────────────────────────────────────────────────────
        match /investments/{investmentId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // ─── Receipts ────────────────────────────────────────────────────────
        match /receipts/{receiptId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        // ─── Rental properties ───────────────────────────────────────────────
        match /rentalProperties/{propertyId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;

          match /rentalIncomes/{incomeId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
          }

          match /rentalExpenses/{expenseId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
          }
        }
      }
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
